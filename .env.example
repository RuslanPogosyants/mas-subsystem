# Database
DATABASE_URL=postgresql+asyncpg://mas:mas@localhost:5432/mas_subsystem

# Redis
REDIS_URL=redis://localhost:6379/0

# GigaChat (fill from Sber developers cabinet in M3)
GIGACHAT_CREDENTIALS=
GIGACHAT_SCOPE=GIGACHAT_API_PERS
GIGACHAT_MODEL=GigaChat-Pro

# Whisper / OCR (used in M2-M3)
WHISPER_MODEL=large-v3
WHISPER_DEVICE=cuda
OCR_GPU=true

# Coordinator
COORD_GLOBAL_DEADLINE_SEC=1800
COORD_RETRY_MAX=2

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=coordinator

# S8 resilience flags
FORCE_REFUSE=
HANG_AGENT=
